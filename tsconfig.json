{
  "include": [
    "next-env.d.ts",
    "app/**/*",
    "client/src/**/*",
    "shared/**/*",
    "server/db.ts",
    "server/storage.ts",
    "server/lib/**/*",
    "lib/**/*",
    "drizzle.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "build",
    "dist",
    "**/*.test.ts",
    "server/index.ts",
    "server/routes.ts",
    "server/vite.ts",
    "server/middleware/**/*",
    "server/lib/blacklist.ts",
    "server/lib/mailerlite.ts",
    "server/lib/sms.ts",
    "server/lib/webhook.ts",
    "scripts/push-to-github.ts"
  ],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./client/src/*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
      "@server/*": [
        "./server/*"
      ],
      "wouter": [
        "./lib/wouter"
      ]
    }
  }
}
